# Project Specifications
# - Android Java API 26 (Oreo, Android 8.0)
# - Auth0 for authentication implementation
!!IMPORTANT!!
ALL Comment and output should be English!, Not Japanese!

# Include main application source files
include: app/src/main/java/com/github/qurore/fittrack/**/*.java

# Include Android resource files
include: app/src/main/res/**/*.xml
include: app/src/main/AndroidManifest.xml

# Include Gradle build configuration files
include: app/build.gradle.kts
include: build.gradle.kts
include: settings.gradle.kts
include: gradle/libs.versions.toml

# Include Auth0 specific configuration files
include: app/src/main/res/values/auth0_credentials.xml
include: app/src/main/res/values/auth0_config.xml
include: app/src/main/assets/auth0_configuration.json

# Include test files
include: app/src/test/java/com/github/qurore/fittrack/**/*.java
include: app/src/androidTest/java/com/github/qurore/fittrack/**/*.java

# Exclude generated and build directories (align with .gitignore)
exclude: .gradle/
exclude: app/build/
exclude: build/
exclude: captures/
exclude: bin/
exclude: gen/
exclude: out/
exclude: .externalNativeBuild/
exclude: .cxx/

# Exclude IDE configuration files
exclude: .idea/
exclude: *.iml

# Exclude local configuration files
exclude: local.properties
exclude: gradle.properties

# Exclude sensitive files
exclude: *.jks
exclude: *.keystore
exclude: google-services.json

# Exclude compiled application files
exclude: *.apk
exclude: *.aab
exclude: *.ap_

# Exclude OS-specific files
exclude: .DS_Store
exclude: Thumbs.db

# SAM related files
include: backend/*
NOTE: managed secrets on Secret Manager
- FitTrackMongoDBURI: mongodb+srv://<username>:<password>@fittrack.oaulk.mongodb.net/fittrack
- FitTrackFirebaseCredentials: Stored in backend/fittrack-6775b-firebase-adminsdk.json

# Execcise Data Model
data class StrengthExercise(
    val id: Long = 0,
    val exerciseName: String,               // Exercise name (bench press, squat, etc.)
    val startTime: Long,                    // Start time (timestamp)
    val duration: Int? = null,              // Total duration (seconds)
    val weight: Float,                      // Weight (kg)
    val reps: Int,                          // Number of repetitions
    val notes: String? = null               // Notes/Additional information
)

data class CardioExercise(
    val id: Long = 0,
    val exerciseName: String,               // Exercise name (running, cycling, etc.)
    val startTime: Long,                    // Start time (timestamp)
    val duration: Int,                      // Duration (seconds)
    val distance: Float? = null,            // Distance (km/m))
    val notes: String? = null               // Notes/Additional information
)

data class FlexibilityExercise(
    val id: Long = 0,
    val exerciseName: String,               // Exercise name (hamstring stretch, etc.)
    val startTime: Long,                    // Start time (timestamp)
    val duration: Int,                      // Stretch duration (seconds)
    val notes: String? = null               // Notes/Additional information
)

data class FunctionalExercise(
    val id: Long = 0,
    val exerciseName: String,               // Exercise name (plank, burpee, etc.)
    val startTime: Long,                    // Start time (timestamp)
    val duration: Int,                      // Duration (seconds)
    val notes: String? = null               // Notes/Additional information
)


